generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id
  github_id     String         @unique
  username      String
  email         String?
  avatar_url    String?
  role          String         @default("analyst")
  is_active     Boolean        @default(true)
  last_login_at DateTime?      @db.Timestamptz
  created_at    DateTime       @default(now()) @db.Timestamptz
  refresh_tokens RefreshToken[]

  @@index([github_id])
}

model RefreshToken {
  id         String   @id
  user_id    String
  token_hash String   @unique
  expires_at DateTime @db.Timestamptz
  created_at DateTime @default(now()) @db.Timestamptz
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
}

model Profile {
  id                  String   @id
  name                String   @unique
  gender              String
  gender_probability  Float
  age                 Int
  age_group           String
  country_id          String   @db.VarChar(2)
  country_name        String   @default("")
  country_probability Float
  created_at          DateTime @default(now()) @db.Timestamptz

  @@index([gender])
  @@index([country_id])
  @@index([age_group])
  @@index([age])
  @@index([gender_probability])
  @@index([country_probability])
  @@index([created_at])
}
